# terminal emulator (Optimizado para tu RTX 5060)
super + Return
	/opt/kitty/bin/kitty

# program launcher
super + d
	/usr/bin/rofi -show run

# close and kill
super + {_,shift + }q
	bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# focus the node in the given direction
super + {_,shift + }{Left,Down,Up,Right}
	bspc node -{f,s} {west,south,north,east}

# focus the next/previous desktop in the current monitor (Perfecto en ANSI)
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

# Custom Resize (Usando variable de entorno para evitar errores de usuario)
super + alt + {Left,Down,Up,Right}
	$HOME/.config/bspwm/scripts/bspwm_resize {west,south,north,east}

# Open Firefox
super + shift + f
	/usr/bin/firefox

# reload sxhkd configuration
super + Escape
	pkill -USR1 -x sxhkd
